<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_notification"
            android:contentDescription="Icono" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WhatsCapture"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Captura y reenvío a Telegram"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="40dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASO 1: Concede los permisos"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnPermissionNotify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Acceso a Notificaciones"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnPermissionStorage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Acceso a Archivos"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASO 2: Inicia el servicio"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INICIAR MONITOREO"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="La app se ejecutará en segundo plano.\nAndroid mostrará una notificación silenciosa\nde servicio activo (requisito del sistema)."
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
